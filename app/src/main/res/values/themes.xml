<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme -->
    <style name="Theme.CashiroCompose" parent="android:Theme.Material.Light.NoActionBar" />
    
    <!-- Splash Screen theme for light mode -->
    <style name="Theme.Cashiro.SplashScreen" parent="Theme.SplashScreen">
        
        <!-- Set splash screen duration (Android 12+) -->
        <item name="windowSplashScreenAnimationDuration">1000</item>
        
        <!-- Set the theme to use after splash screen -->
        <item name="postSplashScreenTheme">@style/Theme.CashiroCompose</item>
    </style>

    <style name="Theme.Cashiro.SplashScreen.Original" parent="Theme.Cashiro.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_original_fg</item>
    </style>

    <style name="Theme.Cashiro.SplashScreen.Anarchy" parent="Theme.Cashiro.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_anarchy_fg</item>
    </style>

    <style name="Theme.Cashiro.SplashScreen.Zenith" parent="Theme.Cashiro.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo_zenith_fg</item>
    </style>
</resources>
